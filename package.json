    "@typescript-eslint/parser": "^8.56.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^3.0.0",
    "esbuild": "^0.28.0",
    "eslint": "10.4.0",
    "glob": "^13.0.0",
    "globals": "^17.0.0",
