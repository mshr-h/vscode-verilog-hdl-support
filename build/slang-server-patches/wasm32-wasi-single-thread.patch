diff --git a/src/WasiExceptionShim.cpp b/src/WasiExceptionShim.cpp
new file mode 100644
index 0000000..0000000
--- /dev/null
+++ b/src/WasiExceptionShim.cpp
@@ -0,0 +1,22 @@
+// SPDX-License-Identifier: MIT
+
+#include <cstdlib>
+
+extern "C" {
+
+void* __cxa_allocate_exception(size_t thrownSize) {
+    return std::malloc(thrownSize);
+}
+
+void __cxa_free_exception(void* thrownException) {
+    std::free(thrownException);
+}
+
+[[noreturn]] void __cxa_throw(void* thrownException, void*, void (*destructor)(void*)) {
+    if (destructor != nullptr && thrownException != nullptr) {
+        destructor(thrownException);
+    }
+    std::free(thrownException);
+    std::abort();
+}
+
+}
