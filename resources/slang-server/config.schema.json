{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "slang-server configuration",
  "type": "object",
  "properties": {
    "flags": {
      "type": "string"
    },
    "index": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "dirs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "excludeDirs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    },
    "build": {
      "type": "string"
    },
    "indexingThreads": {
      "type": "integer",
      "minimum": 0
    },
    "builds": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "glob": {
            "type": "string"
          },
          "command": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
